extends layouts/main.pug

block content
  div.login-container
    h1(style="text-align: center; margin-bottom: 20px;") Login
    div#errorMsg(style="color: #e74c3c; margin-bottom: 15px; display: none; text-align: center; font-weight: bold;")
    form(id="loginForm")
      label(for="email") Email
      input(type="email" id="email" required placeholder="Digite seu email")
      label(for="senha") Senha
      input(type="password" id="senha" required placeholder="Digite sua senha")
      button.btn.btn-primary(type="submit" style="margin-top: 15px; width: 100%;") Entrar

  script.
    document.getElementById('loginForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('email').value;
      const senha = document.getElementById('senha').value;
      
      try {
        const res = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, senha })
        });
        
        const data = await res.json();
        
        if (res.ok) {
          localStorage.setItem('token', data.token);
          window.location.href = '/web/salas';
        } else {
          document.getElementById('errorMsg').innerText = data.message || 'E-mail ou senha incorretos';
          document.getElementById('errorMsg').style.display = 'block';
        }
      } catch (err) {
        document.getElementById('errorMsg').innerText = 'Erro na conexão com o servidor';
        document.getElementById('errorMsg').style.display = 'block';
      }
    });
