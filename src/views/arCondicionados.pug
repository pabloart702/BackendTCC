extends layouts/main.pug

block content
  h1 Lista de Ares-Condicionados
  button.btn.btn-success.admin-only(onclick="mostrarFormAC()") + Novo Ar-Condicionado

  div#formAC(style="display:none; background: white; padding: 15px; margin-bottom: 15px; border-radius: 8px;")
    h3#formACTitle Novo Ar-Condicionado
    input(type="hidden" id="acId")
    input(type="text" id="sala_id" placeholder="ID da Sala (ObjectId)")
    input(type="text" id="marca_modelo" placeholder="Marca/Modelo")
    input(type="text" id="status" placeholder="Status")
    input(type="number" id="temperatura_atual" placeholder="Temperatura Atual")
    input(type="text" id="codigo_ir_ligar" placeholder="IR Ligar")
    input(type="text" id="codigo_ir_desligar" placeholder="IR Desligar")
    input(type="text" id="codigo_ir_temp_23" placeholder="IR Temp 23")
    input(type="text" id="codigo_ir_modo_cool" placeholder="IR Modo Cool")
    button.btn.btn-primary(onclick="salvarAC()") Salvar
    button.btn.btn-danger(onclick="document.getElementById('formAC').style.display='none'") Cancelar

  div#acList

  script.
    document.addEventListener("DOMContentLoaded", async () => {
      const token = localStorage.getItem('token');
      if (!token) {
        window.location.href = '/web/login';
        return;
      }
      
      await carregarAres();
      
      // Checa se é admin para exibir botões de administrador
      const payload = parseJwt(token);
      if (payload && payload.papeis && payload.papeis.includes('admin')) {
        document.querySelectorAll('.admin-only').forEach(el => {
          el.style.display = 'inline-block';
        });
      }
    });

    async function carregarAres() {
      const token = localStorage.getItem('token');
      const listDiv = document.getElementById('acList');
      listDiv.innerHTML = '';
      
      try {
        const res = await fetch('/api/arCondicionados', {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        if (res.ok) {
          const arCondicionados = await res.json();
          const payload = parseJwt(token);
          const isAdmin = payload && payload.papeis && payload.papeis.includes('admin');
          
          if (arCondicionados && arCondicionados.length > 0) {
            arCondicionados.forEach(ac => {
              const card = document.createElement('div');
              card.className = 'card';
              
              // Evitar problemas de aspas nas strings
              const marcaEscaped = ac.marca_modelo ? ac.marca_modelo.replace(/'/g, "\\'") : '';
              const statusEscaped = ac.status ? ac.status.replace(/'/g, "\\'") : '';
              const ligarEscaped = ac.codigo_ir_ligar ? ac.codigo_ir_ligar.replace(/'/g, "\\'") : '';
              const desligarEscaped = ac.codigo_ir_desligar ? ac.codigo_ir_desligar.replace(/'/g, "\\'") : '';
              const temp23Escaped = ac.codigo_ir_temp_23 ? ac.codigo_ir_temp_23.replace(/'/g, "\\'") : '';
              const coolEscaped = ac.codigo_ir_modo_cool ? ac.codigo_ir_modo_cool.replace(/'/g, "\\'") : '';
              
              let tempHtml = '';
              if (ac.temperatura_atual !== undefined && ac.temperatura_atual !== null) {
                tempHtml = `<p><strong>Temperatura Atual: </strong><span>${ac.temperatura_atual}°C</span></p>`;
              }
              
              card.innerHTML = `
                <h3>${ac.marca_modelo}</h3>
                <p>
                  <strong>ID: </strong><span>${ac.id}</span>
                </p>
                <p>
                  <strong>ID da Sala: </strong><span>${ac.sala_id}</span>
                </p>
                <p>
                  <strong>Status: </strong><span>${ac.status}</span>
                </p>
                ${tempHtml}
                <div style="margin-top: 15px;">
                  <button class="btn btn-primary admin-only" style="display: ${isAdmin ? 'inline-block' : 'none'};" onclick="editarAC('${ac.id}', '${ac.sala_id}', '${marcaEscaped}', '${statusEscaped}', '${ac.temperatura_atual || ''}', '${ligarEscaped}', '${desligarEscaped}', '${temp23Escaped}', '${coolEscaped}')">Editar</button>
                  <button class="btn btn-danger admin-only" style="display: ${isAdmin ? 'inline-block' : 'none'};" onclick="deletarAC('${ac.id}')">Excluir</button>
                </div>
              `;
              listDiv.appendChild(card);
            });
          } else {
            listDiv.innerHTML = '<p class="empty-msg">Nenhum ar-condicionado cadastrado no momento.</p>';
          }
        } else {
          listDiv.innerHTML = '<p class="empty-msg">Erro ao carregar ares-condicionados da API.</p>';
        }
      } catch (err) {
        console.error(err);
        listDiv.innerHTML = '<p class="empty-msg">Erro de conexão ao carregar ares-condicionados.</p>';
      }
    }

    function mostrarFormAC() {
      document.getElementById('formACTitle').innerText = 'Novo Ar-Condicionado';
      document.getElementById('acId').value = '';
      document.getElementById('sala_id').value = '';
      document.getElementById('marca_modelo').value = '';
      document.getElementById('status').value = '';
      document.getElementById('temperatura_atual').value = '';
      document.getElementById('codigo_ir_ligar').value = '';
      document.getElementById('codigo_ir_desligar').value = '';
      document.getElementById('codigo_ir_temp_23').value = '';
      document.getElementById('codigo_ir_modo_cool').value = '';
      document.getElementById('formAC').style.display = 'block';
    }

    function editarAC(id, sala_id, marca, status, temp, ligar, desligar, temp23, cool) {
      document.getElementById('formACTitle').innerText = 'Editar Ar-Condicionado';
      document.getElementById('acId').value = id;
      document.getElementById('sala_id').value = sala_id;
      document.getElementById('marca_modelo').value = marca;
      document.getElementById('status').value = status;
      document.getElementById('temperatura_atual').value = temp;
      document.getElementById('codigo_ir_ligar').value = ligar;
      document.getElementById('codigo_ir_desligar').value = desligar;
      document.getElementById('codigo_ir_temp_23').value = temp23;
      document.getElementById('codigo_ir_modo_cool').value = cool;
      document.getElementById('formAC').style.display = 'block';
    }

    async function salvarAC() {
      const id = document.getElementById('acId').value;
      const data = {
        sala_id: document.getElementById('sala_id').value,
        marca_modelo: document.getElementById('marca_modelo').value,
        status: document.getElementById('status').value,
        temperatura_atual: parseInt(document.getElementById('temperatura_atual').value),
        codigo_ir_ligar: document.getElementById('codigo_ir_ligar').value,
        codigo_ir_desligar: document.getElementById('codigo_ir_desligar').value,
        codigo_ir_temp_23: document.getElementById('codigo_ir_temp_23').value,
        codigo_ir_modo_cool: document.getElementById('codigo_ir_modo_cool').value
      };
      
      const token = localStorage.getItem('token');
      const method = id ? 'PATCH' : 'POST';
      const url = id ? `/api/arCondicionados/${id}` : '/api/arCondicionados';

      const res = await fetch(url, {
        method: method,
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify(data)
      });
      if (res.ok) {
        document.getElementById('formAC').style.display = 'none';
        await carregarAres();
      } else {
        const errorData = await res.json();
        let errorMsg = 'Erro ao salvar ar-condicionado.';
        if (errorData.erros && Array.isArray(errorData.erros)) {
          errorMsg = errorData.erros.map(e => e.msg || e.message).join('\n');
        } else if (errorData.message) {
          errorMsg = errorData.message;
        }
        alert(errorMsg);
      }
    }

    async function deletarAC(id) {
      if (!confirm('Deseja excluir este ar-condicionado?')) return;
      const token = localStorage.getItem('token');
      const res = await fetch(`/api/arCondicionados/${id}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) {
        await carregarAres();
      } else {
        const errorData = await res.json();
        let errorMsg = 'Erro ao excluir ar-condicionado.';
        if (errorData.erros && Array.isArray(errorData.erros)) {
          errorMsg = errorData.erros.map(e => e.msg || e.message).join('\n');
        } else if (errorData.message) {
          errorMsg = errorData.message;
        }
        alert(errorMsg);
      }
    }
